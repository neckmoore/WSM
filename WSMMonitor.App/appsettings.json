{
  "LibreHardwareMonitor": {
    "Enabled": false,
    "Cpu": true,
    "Gpu": true,
    "Motherboard": true,
    "MemoryModules": false,
    "Storage": false,
    "FanControllers": false,
    "Psu": false,
    "MaxSensors": 48
  },
  "Agent": {
    "Port": 8787,
    "HistorySampleSeconds": 12
  },
  "Logging": {
    "Enabled": true,
    "Path": "logs/wsm-.log",
    "MinimumLevel": "Information",
    "RetentionDays": 7,
    "HourlySummaryEnabled": true,
    "HourlySummaryIntervalHours": 1
  },
  "History": {
    "SqliteEnabled": false,
    "SqlitePath": "data/metrics-history.db",
    "RetentionDays": 30
  },
  "Sigma": {
    "SuppressionsPath": ""
  },
  "Ui": {
    "Language": "ru",
    "WorkMode": "companion"
  }
}
